rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /seats/{seatId} {
      allow read: if true;
      allow create: if request.auth != null
                   && request.resource.data.occupantUid == request.auth.uid;
      allow update: if request.auth != null
                   && request.auth.uid == resource.data.occupantUid;
      allow delete: if request.auth != null
                   && request.auth.uid == resource.data.occupantUid;
    }
    match /users/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    match /config/{docId} {
      allow read: if true;
      // 認証済みユーザーは統計の増加・管理者登録のみ可能
      // カウンタが減らないことを保証
      allow create: if request.auth != null;
      allow update: if request.auth != null
                   && request.resource.data.totalVisitors >= resource.data.totalVisitors
                   && request.resource.data.totalMinutes >= resource.data.totalMinutes;
    }
  }
}
